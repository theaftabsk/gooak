// 8. PLATFORM SUBSCRIPTIONS
// ── Promo Codes ──────────────────────────────────────────────────────────────
model PromoCode {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code             String    @unique @db.VarChar(60)
  description      String?   @db.Text
  discount_type    String    @db.VarChar(20) // "percent" | "flat"
  discount_value   Decimal   @db.Decimal(10, 2)
  applicable_plans String[]  @default([]) // plan slugs; empty = all plans
  max_uses         Int?
  used_count       Int       @default(0)
  starts_at        DateTime? @db.Timestamptz
  expires_at       DateTime? @db.Timestamptz
  is_active        Boolean   @default(true)
  created_at       DateTime  @default(now()) @db.Timestamptz

  subscriptions ShopSubscription[]

  @@map("promo_codes")
}

// ── Add-ons ───────────────────────────────────────────────────────────────────
model SubscriptionAddon {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String   @db.VarChar(100)
  slug        String   @unique @db.VarChar(60)
  description String?  @db.Text
  price       Decimal  @db.Decimal(10, 2)
  interval    String   @default("monthly") @db.VarChar(20)
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now()) @db.Timestamptz

  shop_addons ShopSubscriptionAddon[]
  plan_addons PlanAddon[]

  @@map("subscription_addons")
}

// ── Which add-ons are bundled / available per plan ───────────────────────────
model PlanAddon {
  plan_id     String  @db.Uuid
  addon_id    String  @db.Uuid
  is_included Boolean @default(false) // true = bundled free with the plan

  plan  SubscriptionPlan  @relation(fields: [plan_id], references: [id], onDelete: Cascade)
  addon SubscriptionAddon @relation(fields: [addon_id], references: [id], onDelete: Cascade)

  @@id([plan_id, addon_id])
  @@map("plan_addons")
}

// ── Subscription Plans ────────────────────────────────────────────────────────
model SubscriptionPlan {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String   @db.VarChar(100)
  slug         String   @unique @db.VarChar(60)
  level        Int      @default(0) // 0=free 1=starter 2=pro 3=enterprise — single source of truth for ordering/gating
  is_free      Boolean  @default(false) // convenience flag; price=0 and is_free=true = always free tier
  price        Decimal  @default(0) @db.Decimal(10, 2)
  interval     String   @default("monthly") @db.VarChar(20) // "monthly" | "yearly"
  max_products Int      @default(50)
  max_orders   Int      @default(100)
  features     String[] @default([])
  is_active    Boolean  @default(true)
  sort_order   Int      @default(0)
  created_at   DateTime @default(now()) @db.Timestamptz

  subscriptions ShopSubscription[]
  plan_addons   PlanAddon[]

  @@map("subscription_plans")
}

// ── Shop Subscription ─────────────────────────────────────────────────────────
model ShopSubscription {
  id            String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shop_id       String  @unique @db.Uuid
  plan_id       String  @db.Uuid
  promo_code_id String? @db.Uuid

  // Status — single source of truth for whether the shop is in good standing
  status String @default("active") @db.VarChar(30)
  // "trialing" | "active" | "past_due" | "cancelled" | "expired"

  // Trial
  is_trial      Boolean   @default(false)
  trial_ends_at DateTime? @db.Timestamptz

  // Billing period
  started_at           DateTime  @default(now()) @db.Timestamptz
  current_period_start DateTime? @db.Timestamptz
  current_period_end   DateTime? @db.Timestamptz
  next_payment_at      DateTime? @db.Timestamptz

  // Cancellation
  cancelled_at  DateTime? @db.Timestamptz
  cancel_reason String?   @db.Text

  // Payment
  payment_status         String    @default("not_required") @db.VarChar(30)
  // "not_required" | "paid" | "unpaid" | "failed" | "refunded"
  last_payment_at        DateTime? @db.Timestamptz
  last_payment_failed_at DateTime? @db.Timestamptz
  payment_failure_reason String?   @db.Text

  // Promo / discount applied at subscription time
  discount_amount Decimal @default(0) @db.Decimal(10, 2)

  created_at DateTime @default(now()) @db.Timestamptz
  updated_at DateTime @default(now()) @updatedAt @db.Timestamptz

  shop       Shop                    @relation(fields: [shop_id], references: [id], onDelete: Cascade)
  plan       SubscriptionPlan        @relation(fields: [plan_id], references: [id])
  promo_code PromoCode?              @relation(fields: [promo_code_id], references: [id], onDelete: SetNull)
  addons     ShopSubscriptionAddon[]
  payments   SubscriptionPayment[]

  @@map("shop_subscriptions")
}

// ── Add-ons attached to a shop's subscription ─────────────────────────────────
model ShopSubscriptionAddon {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  subscription_id String   @db.Uuid
  addon_id        String   @db.Uuid
  quantity        Int      @default(1)
  started_at      DateTime @default(now()) @db.Timestamptz

  subscription ShopSubscription  @relation(fields: [subscription_id], references: [id], onDelete: Cascade)
  addon        SubscriptionAddon @relation(fields: [addon_id], references: [id], onDelete: Cascade)

  @@unique([subscription_id, addon_id])
  @@map("shop_subscription_addons")
}

// ── Subscription Payment History ──────────────────────────────────────────────
model SubscriptionPayment {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  subscription_id String    @db.Uuid
  amount          Decimal   @db.Decimal(10, 2)
  currency        String    @default("USD") @db.Char(3)
  status          String    @db.VarChar(30) // "paid" | "failed" | "refunded" | "pending"
  gateway         String?   @db.VarChar(60) // "razorpay" | "stripe" | "manual"
  transaction_id  String?   @unique @db.VarChar(255)
  invoice_url     String?   @db.Text
  promo_code      String?   @db.VarChar(60)
  discount        Decimal   @default(0) @db.Decimal(10, 2)
  paid_at         DateTime? @db.Timestamptz
  failed_at       DateTime? @db.Timestamptz
  failure_reason  String?   @db.Text
  created_at      DateTime  @default(now()) @db.Timestamptz

  subscription ShopSubscription @relation(fields: [subscription_id], references: [id], onDelete: Cascade)

  @@index([subscription_id], name: "idx_sub_payments_sub")
  @@map("subscription_payments")
}

