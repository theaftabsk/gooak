datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/central"
}

// 1. SHOP & TENANT
model Shop {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name              String   @db.VarChar(150)
  slug              String   @unique @db.VarChar(100)
  owner_id          String?  @db.Uuid
  plan              String   @default("free") @db.VarChar(50)
  status            String   @default("active") @db.VarChar(30)
  logo_url          String?  @db.Text
  description       String?  @db.Text
  currency          String   @default("BDT") @db.Char(3)
  timezone          String   @default("Asia/Dhaka") @db.VarChar(60)
  db_connection_url String?  @db.Text
  created_at        DateTime @default(now()) @db.Timestamptz
  updated_at        DateTime @default(now()) @updatedAt @db.Timestamptz

  owner User? @relation("ShopOwner", fields: [owner_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  users                  User[]                 @relation("ShopUsers")
  domains                ShopDomain[]
  settings               Setting[]
  activity_logs          ActivityLog[]
  categories             Category[]
  brands                 Brand[]
  products               Product[]
  product_gallery        ProductGallery[]
  product_variants       ProductVariant[]
  variant_attributes     VariantAttribute[]
  product_sections       ProductSection[]
  product_faqs           ProductFaq[]
  warehouses             Warehouse[]
  inventory_logs         InventoryLog[]
  carts                  Cart[]
  cart_items             CartItem[]
  orders                 Order[]
  order_items            OrderItem[]
  order_status_logs      OrderStatusLog[]
  order_tracking         OrderTracking[]
  shipping_rates         ShippingRate[]
  coupons                Coupon[]
  coupon_usages          CouponUsage[]
  payment_gateways       PaymentGateway[]
  payments               Payment[]
  taxes                  Tax[]
  reviews                Review[]
  notifications          Notification[]
  banners                Banner[]
  tags                   Tag[]
  collections            Collection[]
  product_media          ProductMedia[]
  product_specifications ProductSpecification[]
  blog_posts             BlogPost[]
  media_library          MediaLibrary[]
  faqs                   Faq[]
  testimonials           Testimonial[]
  home_sections          HomeSection[]
  pages                  Page[]
  subscription           ShopSubscription?
  refunds                Refund[]
  refund_items           RefundItem[]
  wishlists              Wishlist[]
  wishlist_items         WishlistItem[]

  @@map("shops")
}

model ShopDomain {
  id                     String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shop_id                String    @db.Uuid
  domain                 String    @unique @db.VarChar(255)
  type                   String    @default("subdomain") @db.VarChar(20)
  is_primary             Boolean   @default(false)
  status                 String    @default("pending") @db.VarChar(30)
  dns_verification_token String?   @db.VarChar(64)
  verified_at            DateTime? @db.Timestamptz
  created_at             DateTime  @default(now()) @db.Timestamptz

  shop Shop @relation(fields: [shop_id], references: [id], onDelete: Cascade)

  @@index([domain], name: "idx_shop_domain")
  @@map("shop_domains")
}

// 2. SYSTEM
model User {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shop_id       String    @db.Uuid
  name          String    @db.VarChar(150)
  email         String    @unique @db.VarChar(255)
  password_hash String    @db.Text
  password      String?   @db.VarChar(100)
  role          String    @default("staff") @db.VarChar(30)
  avatar_url    String?   @db.Text
  is_active     Boolean   @default(true)
  last_login_at DateTime? @db.Timestamptz
  created_at    DateTime  @default(now()) @db.Timestamptz
  updated_at    DateTime  @default(now()) @updatedAt @db.Timestamptz

  shop              Shop             @relation("ShopUsers", fields: [shop_id], references: [id], onDelete: Cascade)
  owned_shops       Shop[]           @relation("ShopOwner")
  activity_logs     ActivityLog[]
  inventory_logs    InventoryLog[]
  order_status_logs OrderStatusLog[]

  @@map("users")
}

model Setting {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shop_id    String   @db.Uuid
  key        String   @db.VarChar(100)
  value      String   @db.Text
  group      String?  @db.VarChar(60)
  updated_at DateTime @default(now()) @updatedAt @db.Timestamptz

  shop Shop @relation(fields: [shop_id], references: [id], onDelete: Cascade)

  @@unique([shop_id, key])
  @@map("settings")
}

model ActivityLog {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shop_id     String   @db.Uuid
  user_id     String?  @db.Uuid
  action      String   @db.VarChar(100)
  entity_type String?  @db.VarChar(60)
  entity_id   String?  @db.Uuid
  metadata    Json     @default("{}")
  ip_address  String?  @db.VarChar(45)
  created_at  DateTime @default(now()) @db.Timestamptz

  shop Shop  @relation(fields: [shop_id], references: [id], onDelete: Cascade)
  user User? @relation(fields: [user_id], references: [id], onDelete: SetNull)

  @@index([shop_id, created_at(sort: Desc)], name: "idx_activity_shop_time")
  @@map("activity_logs")
}

// 3. PRODUCT CATALOG
model Category {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shop_id      String   @db.Uuid
  parent_id    String?  @db.Uuid
  name         String   @db.VarChar(150)
  slug         String   @db.VarChar(150)
  image_url    String?  @db.Text
  sort_order   Int      @default(0)
  is_active    Boolean  @default(true)
  show_in_menu Boolean  @default(true)
  created_at   DateTime @default(now()) @db.Timestamptz

  shop     Shop       @relation(fields: [shop_id], references: [id], onDelete: Cascade)
  parent   Category?  @relation("CategoryTree", fields: [parent_id], references: [id], onDelete: SetNull)
  children Category[] @relation("CategoryTree")
  products Product[]

  @@unique([shop_id, slug])
  @@map("categories")
}

model Brand {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shop_id    String   @db.Uuid
  name       String   @db.VarChar(150)
  slug       String   @db.VarChar(150)
  logo_url   String?  @db.Text
  is_active  Boolean  @default(true)
  created_at DateTime @default(now()) @db.Timestamptz

  shop     Shop      @relation(fields: [shop_id], references: [id], onDelete: Cascade)
  products Product[]

  @@unique([shop_id, slug])
  @@map("brands")
}

model Product {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shop_id          String   @db.Uuid
  category_id      String?  @db.Uuid
  brand_id         String?  @db.Uuid
  name             String   @db.VarChar(255)
  slug             String   @db.VarChar(255)
  description      String?  @db.Text
  short_desc       String?  @db.Text
  price            Decimal  @db.Decimal(12, 2)
  compare_price    Decimal? @db.Decimal(12, 2)
  cost_price       Decimal? @db.Decimal(12, 2)
  master_sku       String?  @db.VarChar(100)
  status           String   @default("draft") @db.VarChar(30)
  is_featured      Boolean  @default(false)
  has_variants     Boolean  @default(false)
  tax_id           String?  @db.Uuid
  total_sold       Int      @default(0)
  meta_title       String?  @db.VarChar(255)
  meta_description String?  @db.Text
  custom_sections  Json?    @default("[]")
  hsn_code         String?  @db.VarChar(50)
  youtube_url      String?  @db.Text
  supplier_name    String?  @db.VarChar(150)
  supplier_cost    Decimal? @db.Decimal(12, 2)
  supplier_link    String?  @db.Text
  weight           Decimal? @db.Decimal(10, 2)
  length           Decimal? @db.Decimal(10, 2)
  width            Decimal? @db.Decimal(10, 2)
  height           Decimal? @db.Decimal(10, 2)
  allow_backorders Boolean  @default(false)
  visibility       String   @default("visible") @db.VarChar(30)
  product_tags     String[] @default([])
  label            String?  @db.VarChar(50)
  best_seller      Boolean  @default(false)
  new_arrival      Boolean  @default(false)
  trending         Boolean  @default(false)
  enable_reviews   Boolean  @default(true)
  verified_only    Boolean  @default(false)
  seo_keywords     String?  @db.Text
  canonical_url    String?  @db.Text
  og_title         String?  @db.VarChar(255)
  og_description   String?  @db.Text
  og_image         String?  @db.Text
  schema_markup    Json?    @default("{}")
  is_digital       Boolean  @default(false)
  download_url     String?  @db.Text
  download_limit   Int?
  license_key      String?  @db.Text
  view_count       Int      @default(0)
  wishlist_count   Int      @default(0)
  cart_count       Int      @default(0)
  purchase_count   Int      @default(0)
  flash_sale       Boolean  @default(false)
  deal_of_the_day  Boolean  @default(false)
  recommended      Boolean  @default(false)
  recently_added   Boolean  @default(false)
  created_at       DateTime @default(now()) @db.Timestamptz
  updated_at       DateTime @default(now()) @updatedAt @db.Timestamptz

  shop           Shop                   @relation(fields: [shop_id], references: [id], onDelete: Cascade)
  category       Category?              @relation(fields: [category_id], references: [id], onDelete: SetNull)
  brand          Brand?                 @relation(fields: [brand_id], references: [id], onDelete: SetNull)
  tax            Tax?                   @relation(fields: [tax_id], references: [id], onDelete: SetNull)
  gallery        ProductGallery[]
  variants       ProductVariant[]
  faqs           ProductFaq[]
  reviews        Review[]
  tags           ProductTag[]
  media          ProductMedia[]
  collections    CollectionProduct[]
  specifications ProductSpecification[]

  @@unique([shop_id, slug])
  @@index([shop_id], name: "idx_products_shop")
  @@map("products")
}

model ProductGallery {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shop_id    String   @db.Uuid
  product_id String   @db.Uuid
  url        String   @db.Text
  alt_text   String?  @db.Text
  sort_order Int      @default(0)
  is_cover   Boolean  @default(false)
  created_at DateTime @default(now()) @db.Timestamptz

  shop    Shop    @relation(fields: [shop_id], references: [id], onDelete: Cascade)
  product Product @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@map("product_gallery")
}

model ProductVariant {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shop_id         String   @db.Uuid
  product_id      String   @db.Uuid
  sku             String   @unique @db.VarChar(100)
  label           String?  @db.VarChar(255)
  price           Decimal  @db.Decimal(12, 2)
  compare_price   Decimal? @db.Decimal(12, 2)
  cost_price      Decimal? @db.Decimal(12, 2)
  stock_qty       Int      @default(0)
  low_stock_at    Int      @default(5)
  track_inventory Boolean  @default(true)
  reserved_qty    Int      @default(0)
  available_qty   Int      @default(0)
  barcode         String?  @db.VarChar(100)
  weight          Decimal? @db.Decimal(10, 2)
  length          Decimal? @db.Decimal(10, 2)
  width           Decimal? @db.Decimal(10, 2)
  height          Decimal? @db.Decimal(10, 2)
  image_url       String?  @db.Text
  total_sold      Int      @default(0)
  is_active       Boolean  @default(true)
  sort_order      Int      @default(0)
  created_at      DateTime @default(now()) @db.Timestamptz
  updated_at      DateTime @default(now()) @updatedAt @db.Timestamptz

  shop           Shop               @relation(fields: [shop_id], references: [id], onDelete: Cascade)
  product        Product            @relation(fields: [product_id], references: [id], onDelete: Cascade)
  attributes     VariantAttribute[]
  inventory_logs InventoryLog[]
  cart_items     CartItem[]
  order_items    OrderItem[]
  wishlist_items WishlistItem[]

  @@index([product_id], name: "idx_variants_product")
  @@index([sku], name: "idx_variants_sku")
  @@index([shop_id, stock_qty], name: "idx_variant_stock")
  @@map("product_variants")
}

model VariantAttribute {
  id         String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shop_id    String @db.Uuid
  variant_id String @db.Uuid
  attr_key   String @db.VarChar(60)
  attr_value String @db.VarChar(150)
  sort_order Int    @default(0)

  shop    Shop           @relation(fields: [shop_id], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variant_id], references: [id], onDelete: Cascade)

  @@map("variant_attributes")
}

model ProductSection {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shop_id    String   @db.Uuid
  title      String   @db.VarChar(200)
  type       String   @db.VarChar(50)
  config     Json     @default("{}")
  sort_order Int      @default(0)
  is_active  Boolean  @default(true)
  created_at DateTime @default(now()) @db.Timestamptz

  shop Shop @relation(fields: [shop_id], references: [id], onDelete: Cascade)

  @@map("product_sections")
}

model ProductFaq {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shop_id    String   @db.Uuid
  product_id String   @db.Uuid
  question   String   @db.Text
  answer     String   @db.Text
  sort_order Int      @default(0)
  created_at DateTime @default(now()) @db.Timestamptz

  shop    Shop    @relation(fields: [shop_id], references: [id], onDelete: Cascade)
  product Product @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@map("product_faqs")
}

// 4. INVENTORY
model Warehouse {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shop_id    String   @db.Uuid
  name       String   @db.VarChar(150)
  address    String?  @db.Text
  is_active  Boolean  @default(true)
  created_at DateTime @default(now()) @db.Timestamptz

  shop Shop           @relation(fields: [shop_id], references: [id], onDelete: Cascade)
  logs InventoryLog[]

  @@map("warehouses")
}

model InventoryLog {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shop_id      String   @db.Uuid
  variant_id   String   @db.Uuid
  warehouse_id String   @db.Uuid
  type         String   @db.VarChar(30)
  qty_change   Int
  qty_after    Int
  ref_id       String?  @db.Uuid
  note         String?  @db.Text
  created_by   String?  @db.Uuid
  created_at   DateTime @default(now()) @db.Timestamptz

  shop      Shop           @relation(fields: [shop_id], references: [id], onDelete: Cascade)
  variant   ProductVariant @relation(fields: [variant_id], references: [id], onDelete: Cascade)
  warehouse Warehouse      @relation(fields: [warehouse_id], references: [id], onDelete: Cascade)
  operator  User?          @relation(fields: [created_by], references: [id], onDelete: SetNull)

  @@index([variant_id], name: "idx_inventory_variant")
  @@map("inventory_logs")
}

// 5. CART & ORDER
model Cart {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shop_id     String    @db.Uuid
  customer_id String?   @db.Uuid
  session_id  String?   @unique @db.VarChar(255)
  coupon_id   String?   @db.Uuid
  expires_at  DateTime? @db.Timestamptz
  created_at  DateTime  @default(now()) @db.Timestamptz
  updated_at  DateTime  @default(now()) @updatedAt @db.Timestamptz

  shop   Shop       @relation(fields: [shop_id], references: [id], onDelete: Cascade)
  coupon Coupon?    @relation(fields: [coupon_id], references: [id], onDelete: SetNull)
  items  CartItem[]

  @@index([session_id], name: "idx_cart_session")
  @@map("carts")
}

model CartItem {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shop_id    String   @db.Uuid
  cart_id    String   @db.Uuid
  variant_id String   @db.Uuid
  qty        Int      @default(1)
  unit_price Decimal  @db.Decimal(12, 2)
  created_at DateTime @default(now()) @db.Timestamptz

  shop    Shop           @relation(fields: [shop_id], references: [id], onDelete: Cascade)
  cart    Cart           @relation(fields: [cart_id], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variant_id], references: [id], onDelete: Cascade)

  @@unique([cart_id, variant_id])
  @@index([cart_id], name: "idx_cart_items_cart")
  @@map("cart_items")
}

model Order {
  id                   String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shop_id              String    @db.Uuid
  customer_id          String?   @db.Uuid
  order_number         String    @unique @db.VarChar(30)
  status               String    @default("pending") @db.VarChar(30)
  subtotal             Decimal   @db.Decimal(12, 2)
  discount_amount      Decimal   @default(0) @db.Decimal(12, 2)
  shipping_amount      Decimal   @default(0) @db.Decimal(12, 2)
  tax_amount           Decimal   @default(0) @db.Decimal(12, 2)
  total                Decimal   @db.Decimal(12, 2)
  coupon_id            String?   @db.Uuid
  shipping_rate_id     String?   @db.Uuid
  shipping_address     Json
  billing_address      Json?
  notes                String?   @db.Text
  // Guest order info (null when customer_id is set)
  guest_email          String?   @db.VarChar(255)
  guest_name           String?   @db.VarChar(150)
  guest_phone          String?   @db.VarChar(30)
  // Coupon snapshot (code preserved even after coupon is deleted/expired)
  coupon_code          String?   @db.VarChar(60)
  // Shipping & Tracking
  courier_name         String?   @db.VarChar(100)
  tracking_number      String?   @db.VarChar(100)
  tracking_url         String?   @db.Text
  dispatched_at        DateTime? @db.Timestamptz
  expected_delivery_at DateTime? @db.Timestamptz
  // Fulfillment
  fulfillment_status   String    @default("unfulfilled") @db.VarChar(30)
  // Cancellation
  cancelled_at         DateTime? @db.Timestamptz
  cancel_reason        String?   @db.Text
  // Refund: none | requested | partial | refunded
  refund_status        String    @default("none") @db.VarChar(30)
  // Staff notes (internal only)
  staff_notes          String?   @db.Text
  // Payment snapshot
  paid_amount          Decimal?  @db.Decimal(12, 2)
  payment_method       String?   @db.VarChar(50)
  created_at           DateTime  @default(now()) @db.Timestamptz
  updated_at           DateTime  @default(now()) @updatedAt @db.Timestamptz

  shop          Shop             @relation(fields: [shop_id], references: [id], onDelete: Cascade)
  coupon        Coupon?          @relation(fields: [coupon_id], references: [id], onDelete: SetNull)
  shipping_rate ShippingRate?    @relation(fields: [shipping_rate_id], references: [id], onDelete: SetNull)
  items         OrderItem[]
  status_logs   OrderStatusLog[]
  tracking      OrderTracking[]
  payments      Payment[]
  refunds       Refund[]
  coupon_usages CouponUsage[]

  @@unique([shop_id, order_number])
  @@index([shop_id], name: "idx_orders_shop")
  @@index([order_number], name: "idx_order_number")
  @@map("orders")
}

model OrderItem {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shop_id         String   @db.Uuid
  order_id        String   @db.Uuid
  variant_id      String   @db.Uuid
  product_snap    Json
  qty             Int
  unit_price      Decimal  @db.Decimal(12, 2)
  discount_amount Decimal  @default(0) @db.Decimal(12, 2)
  tax_amount      Decimal  @default(0) @db.Decimal(12, 2)
  line_total      Decimal  @db.Decimal(12, 2)
  refunded_qty    Int      @default(0)
  created_at      DateTime @default(now()) @db.Timestamptz

  shop         Shop           @relation(fields: [shop_id], references: [id], onDelete: Cascade)
  order        Order          @relation(fields: [order_id], references: [id], onDelete: Cascade)
  variant      ProductVariant @relation(fields: [variant_id], references: [id], onDelete: Cascade)
  refund_items RefundItem[]

  @@index([order_id], name: "idx_order_items_order")
  @@map("order_items")
}

model OrderStatusLog {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shop_id     String   @db.Uuid
  order_id    String   @db.Uuid
  from_status String?  @db.VarChar(30)
  to_status   String   @db.VarChar(30)
  note        String?  @db.Text
  changed_by  String?  @db.Uuid
  created_at  DateTime @default(now()) @db.Timestamptz

  shop     Shop  @relation(fields: [shop_id], references: [id], onDelete: Cascade)
  order    Order @relation(fields: [order_id], references: [id], onDelete: Cascade)
  operator User? @relation(fields: [changed_by], references: [id], onDelete: SetNull)

  @@map("order_status_logs")
}

model ShippingRate {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shop_id    String   @db.Uuid
  name       String   @db.VarChar(150)
  rate       Decimal  @db.Decimal(10, 2)
  free_above Decimal  @default(0) @db.Decimal(10, 2)
  zone_label String?  @db.VarChar(100)
  is_active  Boolean  @default(true)
  created_at DateTime @default(now()) @db.Timestamptz

  shop   Shop    @relation(fields: [shop_id], references: [id], onDelete: Cascade)
  orders Order[]

  @@map("shipping_rates")
}

model Coupon {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shop_id            String    @db.Uuid
  code               String    @db.VarChar(60)
  type               String    @db.VarChar(20)
  value              Decimal   @db.Decimal(10, 2)
  min_order          Decimal   @default(0) @db.Decimal(10, 2)
  applies_to         String    @default("all") @db.VarChar(30)
  target_ids         String[]  @default([])
  usage_limit        Int?
  per_customer_limit Int?
  used_count         Int       @default(0)
  free_shipping      Boolean   @default(false)
  starts_at          DateTime? @db.Timestamptz
  ends_at            DateTime? @db.Timestamptz
  is_active          Boolean   @default(true)
  created_at         DateTime  @default(now()) @db.Timestamptz

  shop   Shop          @relation(fields: [shop_id], references: [id], onDelete: Cascade)
  carts  Cart[]
  orders Order[]
  usages CouponUsage[]

  @@unique([shop_id, code])
  @@map("coupons")
}

// 6. PAYMENT
model PaymentGateway {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shop_id    String   @db.Uuid
  name       String   @db.VarChar(100)
  slug       String   @db.VarChar(60)
  config     Json     @default("{}")
  is_active  Boolean  @default(true)
  sort_order Int      @default(0)
  created_at DateTime @default(now()) @db.Timestamptz

  shop     Shop      @relation(fields: [shop_id], references: [id], onDelete: Cascade)
  payments Payment[]

  @@map("payment_gateways")
}

model Payment {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shop_id        String    @db.Uuid
  order_id       String    @db.Uuid
  gateway_id     String    @db.Uuid
  amount         Decimal   @db.Decimal(12, 2)
  currency       String    @default("INR") @db.Char(3)
  status         String    @default("pending") @db.VarChar(30)
  transaction_id String?   @unique @db.VarChar(255)
  gateway_resp   Json      @default("{}")
  paid_at        DateTime? @db.Timestamptz
  created_at     DateTime  @default(now()) @db.Timestamptz

