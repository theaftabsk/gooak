datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/tenant"
}

model Customer {
  id            String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shop_id       String         @db.Uuid
  name          String?        @db.VarChar(150)
  email         String?        @db.VarChar(255)
  phone         String?        @db.VarChar(30)
  password_hash String?        @db.Text
  guest_token   String?        @unique @db.VarChar(255)
  is_verified   Boolean        @default(false)
  avatar_url    String?        @db.Text
  total_orders  Int            @default(0)
  total_spent   Decimal        @default(0) @db.Decimal(14, 2)
  created_at    DateTime       @default(now()) @db.Timestamptz
  updated_at    DateTime       @default(now()) @updatedAt @db.Timestamptz

  addresses     Address[]

  @@unique([shop_id, email])
  @@index([shop_id], name: "idx_customers_shop")
  @@map("customers")
}

model Address {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shop_id       String   @db.Uuid
  customer_id   String   @db.Uuid
  type          String   @default("shipping") @db.VarChar(20)
  full_name     String   @db.VarChar(150)
  phone         String?  @db.VarChar(30)
  address_line1 String   @db.Text
  address_line2 String?  @db.Text
  city          String   @db.VarChar(100)
  state         String?  @db.VarChar(100)
  postal_code   String?  @db.VarChar(20)
  country       String   @default("BD") @db.Char(2)
  is_default    Boolean  @default(false)
  created_at    DateTime @default(now()) @db.Timestamptz

  customer      Customer @relation(fields: [customer_id], references: [id], onDelete: Cascade)

  @@map("addresses")
}
