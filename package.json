{
  "name": "Oak-Commerce",
  "version": "1.0.0",
  "private": true,
  "description": "Oak Commerce Monorepo",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "clean": "turbo run clean && rm -rf node_modules .turbo",
    "dev:backend": "turbo run dev --filter=backend",
    "dev:dashboard": "turbo run dev --filter=merchant-dashboard",
    "dev:storefront": "turbo run dev --filter=storefront-live",
    "dev:admin": "turbo run dev --filter=super-admin",
    "db:generate": "pnpm --filter backend exec prisma generate",
    "db:migrate": "pnpm --filter backend exec prisma migrate dev",
    "db:studio": "pnpm --filter backend exec prisma studio"
  },
  "packageManager": "pnpm@10.34.1",
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "turbo": "latest"
  }
}