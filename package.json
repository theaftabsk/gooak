{
  "name": "Oak-Commerce",
  "version": "1.0.0",
  "private": true,
  "description": "Oak Commerce Monorepo",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --filter=!backend",
    "dev:all": "turbo run dev",
    "lint": "turbo run lint",
    "clean": "turbo run clean && rm -rf node_modules .turbo",
    "dev:backend": "turbo run dev --filter=backend",
    "dev:dashboard": "turbo run dev --filter=merchant-dashboard",
    "dev:storefront": "turbo run dev --filter=storefront-live",
    "dev:admin": "turbo run dev --filter=super-admin",
    "db:generate": "pnpm --filter backend run db:generate",
    "db:sync": "pnpm --filter backend run db:sync",
    "db:setup": "pnpm --filter backend run db:setup",
    "db:seed": "pnpm --filter backend run db:seed",
    "db:rebuild": "pnpm --filter backend run db:rebuild",
    "db:bootstrap": "pnpm --filter backend run db:bootstrap",
    "db:migrate": "pnpm --filter backend run db:migrate:central",
    "db:studio": "pnpm --filter backend exec prisma studio --schema=prisma/schema.prisma",
    "db:studio:tenant": "pnpm --filter backend exec prisma studio --schema=prisma/tenant.prisma"
  },
  "packageManager": "pnpm@10.34.1",
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "turbo": "latest"
  }
}